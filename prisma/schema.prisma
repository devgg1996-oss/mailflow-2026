// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Enums (DDL의 DEFAULT / COMMENT에 맞춤) ---

enum ActiveStatus {
  ACTIVE
  INACTIVE
}

enum ContactType {
  GOOGLE_SHEET
}

// --- Models ---

model User {
  id             BigInt          @id @default(autoincrement()) @map("id")
  guid           String          @unique @map("guid") @db.VarChar(40)
  name           String          @map("name")
  provider       String          @map("provider")
  providerId     String          @map("provider_id")
  email          String          @unique @map("email")
  accessToken    String?         @map("access_token") @db.Text
  refreshToken   String?         @map("refresh_token") @db.Text
  lastLoginAt    DateTime?       @map("last_login_at")
  createdAt      DateTime?       @map("created_at")
  updatedAt      DateTime?       @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")
  sheets         Sheet[]
  campaigns      Campaign[]
  emailTemplates EmailTemplate[]
  contacts       Contact[]

  @@unique([id, guid])
  @@map("user")
}

model Sheet {
  id   BigInt @id @default(autoincrement()) @map("id")
  guid String @unique @map("guid") @db.VarChar(40)

  sheetId   String          @map("sheet_id") /// unique (애플리케이션 레벨)
  title     String?         @map("title")
  createdAt DateTime?       @map("created_at")
  updatedAt DateTime?       @map("updated_at")
  deletedAt DateTime?       @map("deleted_at")
  userId    BigInt          @map("user_id")
  userGuid  String          @map("user_guid") @db.VarChar(40)
  user      User            @relation(fields: [userId, userGuid], references: [id, guid])
  contacts  Contact[]
  campaigns SheetCampaign[]

  @@unique([id, guid])
  @@map("sheet")
}

model Campaign {
  id                     BigInt                  @id @default(autoincrement()) @map("id")
  guid                   String                  @unique @map("guid") @db.VarChar(40)
  title                  String?                 @map("title")
  type                   String?                 @map("type") /// unique (COMMENT)
  status                 String?                 @map("status")
  createdAt              DateTime?               @map("created_at")
  updatedAt              DateTime?               @map("updated_at")
  deletedAt              DateTime?               @map("deleted_at")
  userId                 BigInt                  @map("user_id")
  userGuid               String                  @map("user_guid") @db.VarChar(40)
  user                   User                    @relation(fields: [userId, userGuid], references: [id, guid])
  campaignEmailTemplates CampaignEmailTemplate[]
  sheetCampaigns         SheetCampaign[]

  @@unique([id, guid])
  @@map("campaign")
}

model EmailTemplate {
  id                     BigInt                  @id @default(autoincrement()) @map("id")
  guid                   String                  @unique @map("guid") @db.VarChar(40)
  title                  String?                 @map("title")
  body                   String                  @map("body") @db.VarChar(255) /// 치환변수는 {{}} 이렇게 표시
  status                 ActiveStatus            @default(ACTIVE) @map("status") /// 활성, 비활성 등
  createdAt              DateTime?               @map("created_at")
  updatedAt              DateTime?               @map("updated_at")
  deletedAt              DateTime?               @map("deleted_at")
  userId                 BigInt                  @map("user_id")
  userGuid               String                  @map("user_guid") @db.VarChar(40)
  user                   User                    @relation(fields: [userId, userGuid], references: [id, guid])
  campaignEmailTemplates CampaignEmailTemplate[]
  sendEmailHistories     SendEmailHistory[]

  @@unique([id, guid])
  @@map("email_template")
}

model CampaignEmailTemplate {
  id                BigInt             @id @default(autoincrement()) @map("id")
  guid              String             @unique @map("guid") @db.VarChar(40)
  title             String?            @map("title")
  body              String             @map("body") @db.VarChar(255) /// 치환변수는 {{}} 이렇게 표시
  status            ActiveStatus       @default(ACTIVE) @map("status")
  createdAt         DateTime?          @map("created_at")
  updatedAt         DateTime?          @map("updated_at")
  deletedAt         DateTime?          @map("deleted_at")
  campaignId        BigInt             @map("campaign_id")
  campaignGuid      String             @map("campaign_guid") @db.VarChar(40)
  emailTemplateId   BigInt             @map("email_template_id")
  emailTemplateGuid String             @map("email_template_guid") @db.VarChar(40)
  campaign          Campaign           @relation(fields: [campaignId, campaignGuid], references: [id, guid])
  emailTemplate     EmailTemplate      @relation(fields: [emailTemplateId, emailTemplateGuid], references: [id, guid])
  sendHistories     SendEmailHistory[]

  @@unique([id, guid])
  @@map("campaign_email_template")
}

model Contact {
  id   BigInt @id @default(autoincrement()) @map("id")
  guid String @unique @map("guid") @db.VarChar(40)

  type               ContactType        @default(GOOGLE_SHEET) @map("type") /// 구글시트 추출, 직접 입력 등
  name               String?            @map("name")
  email              String             @map("email")
  meta               String?            @map("meta") @db.VarChar(255)
  viewCount          Int                @default(0) @map("response_count")
  createdAt          DateTime?          @map("created_at")
  updatedAt          DateTime?          @map("updated_at")
  deletedAt          DateTime?          @map("deleted_at")
  userId             BigInt             @map("user_id")
  userGuid           String             @map("user_guid") @db.VarChar(40)
  sheetId            BigInt             @map("sheet_id")
  sheetGuid          String             @map("sheet_guid") @db.VarChar(40)
  user               User               @relation(fields: [userId, userGuid], references: [id, guid])
  sheet              Sheet              @relation(fields: [sheetId, sheetGuid], references: [id, guid])
  sendEmailHistories SendEmailHistory[]

  @@unique([sheetId, email])
  @@unique([id, guid])
  @@map("contact")
}

model SheetCampaign {
  id           BigInt    @id @default(autoincrement()) @map("id")
  guid         String    @unique @map("guid") @db.VarChar(40)
  title        String?   @map("title")
  type         String?   @map("type")
  status       String?   @map("status")
  createdAt    DateTime? @map("created_at")
  updatedAt    DateTime? @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  campaignId   BigInt    @map("campaign_id")
  campaignGuid String    @map("campaign_guid") @db.VarChar(40)
  sheetId      BigInt    @map("sheet_id")
  sheetGuid    String    @map("sheet_guid") @db.VarChar(40)
  campaign     Campaign  @relation(fields: [campaignId, campaignGuid], references: [id, guid])
  sheet        Sheet     @relation(fields: [sheetId, sheetGuid], references: [id, guid])

  @@unique([id, guid])
  @@map("sheet_campaign")
}

model SendEmailHistory {
  id                        BigInt                @id @default(autoincrement()) @map("id")
  guid                      String                @unique @map("guid") @db.VarChar(40)
  body                      String                @map("body") /// 치환변수는 {{}} 이렇게 표시
  status                    String                @map("status")
  sendedAt                  DateTime?             @map("sended_at")
  createdAt                 DateTime?             @map("created_at")
  updatedAt                 DateTime?             @map("updated_at")
  deletedAt                 DateTime?             @map("deleted_at")
  emailTemplateId           BigInt                @map("email_template_id")
  emailTemplateGuid         String                @map("email_template_guid") @db.VarChar(40)
  contactId                 BigInt                @map("contact_id")
  contactGuid               String                @map("contact_guid") @db.VarChar(40)
  campaignEmailTemplateId   BigInt                @map("campaign_email_template_id")
  campaignEmailTemplateGuid String                @map("campaign_email_template_guid") @db.VarChar(40)
  emailTemplate             EmailTemplate         @relation(fields: [emailTemplateId, emailTemplateGuid], references: [id, guid])
  contact                   Contact               @relation(fields: [contactId, contactGuid], references: [id, guid])
  campaignEmailTemplate     CampaignEmailTemplate @relation(fields: [campaignEmailTemplateId, campaignEmailTemplateGuid], references: [id, guid])

  @@unique([id, guid])
  @@map("send_email_history")
}
